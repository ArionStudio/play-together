{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "useDefineForClassFields": true,
    "types": ["vite/client"],
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@convex/*": ["./convex/_generated/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/game-contracts": ["../../packages/game-contracts/src/index.ts"],
      "@workspace/game-contracts/*": ["../../packages/game-contracts/src/*"],
      "@workspace/game-core": ["../../packages/game-core/src/index.ts"],
      "@workspace/game-core/*": ["../../packages/game-core/src/*"],
      "@workspace/minesweeper-engine": ["../../packages/minesweeper-engine/src/index.ts"],
      "@workspace/minesweeper-engine/*": ["../../packages/minesweeper-engine/src/*"],
      "@workspace/sudoku-engine": ["../../packages/sudoku-engine/src/index.ts"],
      "@workspace/sudoku-engine/*": ["../../packages/sudoku-engine/src/*"]
    }
  },
  "include": ["src"]
}
